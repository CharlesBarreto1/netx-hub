# NetX Hub — configuração. Copie para .env e preencha.

# Banco (Postgres) do Hub — separado do banco de cada NetX cliente.
DATABASE_URL=postgresql://netxhub:netxhub@localhost:5432/netxhub?schema=public

# Porta da API do Hub.
PORT=4000

# Chave PRIVADA de assinatura de licença (Ed25519, pkcs8/der em base64).
# A pública correspondente fica embarcada no NetX
# (packages/shared/src/licensing/public-key.ts). Gere um par com:
#   npm run keygen
# Em produção, guarde isto num cofre/secret manager — NUNCA no git.
LICENSE_PRIVATE_KEY_B64=

# Token de acesso ao painel/admin do Hub (staff NetX). Header: x-admin-token.
# Gere um valor forte e aleatório.
HUB_ADMIN_TOKEN=

# Validade do token de licença renovado a cada heartbeat (dias).
LICENSE_TOKEN_TTL_DAYS=7
# Janela extra de graça após expirar, antes do bloqueio duro (dias).
LICENSE_GRACE_DAYS=2

# Segredo do JWT da central do cliente (login e-mail+senha). Mín. 16 chars.
HUB_PORTAL_JWT_SECRET=

# Desbloqueio em confiança (autoatendimento do cliente bloqueado por atraso).
TRUST_UNLOCK_DAYS=3
TRUST_UNLOCK_MAX_PER_INVOICE=1
