# NetX Hub — configuração. Copie para .env e preencha.

# Banco (Postgres) do Hub — separado do banco de cada NetX cliente.
DATABASE_URL=postgresql://netxhub:netxhub@localhost:5432/netxhub?schema=public

# Porta da API do Hub.
PORT=4000

# Chave PRIVADA de assinatura de licença (Ed25519, pkcs8/der em base64).
# A pública correspondente fica embarcada no NetX
# (packages/shared/src/licensing/public-key.ts). Gere um par com:
#   npm run keygen
# Em produção, guarde isto num cofre/secret manager — NUNCA no git.
LICENSE_PRIVATE_KEY_B64=

# Segredo do JWT do painel admin (equipe NetX). Mín. 16 chars.
# Crie o primeiro usuário com: ADMIN_EMAIL=.. ADMIN_PASSWORD=.. npm run create-admin
HUB_ADMIN_JWT_SECRET=

# Validade do token de licença renovado a cada heartbeat (dias).
LICENSE_TOKEN_TTL_DAYS=7
# Janela extra de graça após expirar, antes do bloqueio duro (dias).
LICENSE_GRACE_DAYS=2

# Segredo do JWT da central do cliente (login e-mail+senha). Mín. 16 chars.
HUB_PORTAL_JWT_SECRET=

# Desbloqueio em confiança (autoatendimento do cliente bloqueado por atraso).
TRUST_UNLOCK_DAYS=3
TRUST_UNLOCK_MAX_PER_INVOICE=1

# URL pública do Hub (pra montar a notification_url do webhook EFI).
HUB_PUBLIC_URL=https://hub.netx.com.br

# --- Pagamento EFI (Pix) — opcional. Vazio = pagamento online desligado
# (cliente paga por fora, admin dá baixa manual). ---
EFI_ENABLED=false
EFI_ENVIRONMENT=PRODUCTION            # PRODUCTION | SANDBOX
EFI_CLIENT_ID=
EFI_CLIENT_SECRET=
# Certificado .p12 da EFI em base64 (obrigatório p/ Pix). Gere com:
#   base64 -i certificado.p12   (macOS)  /  base64 -w0 certificado.p12 (linux)
EFI_CERTIFICATE_BASE64=
EFI_CERTIFICATE_PASSWORD=
EFI_PIX_KEY=                          # chave Pix recebedora da NetX
EFI_PIX_EXPIRATION_DAYS=3
# Token aleatório no path do webhook (a EFI chama /v1/efi/webhook/pix/<token>).
EFI_WEBHOOK_TOKEN=
